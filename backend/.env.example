GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# Target PostgreSQL database (the DB you want to chat with)
TARGET_DB_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE

# --- Optional: Qdrant (Schema Vector Store) ---
# Leave USE_QDRANT=false to skip full vector search and use raw schema instead
USE_QDRANT=false
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=db_schema

# --- Optional: Redis (Query Cache) ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# --- Security ---
MAX_QUERY_ROWS=1000
ALLOWED_SQL_PREFIXES=SELECT,WITH

# --- CORS ---
FRONTEND_URL=http://localhost:3000
