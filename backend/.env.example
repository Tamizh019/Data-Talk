GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-pro-preview 

TARGET_DB_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/YOUR_DB_NAME

# --- System DB (permanent Supabase for all vector storage) ---
SYSTEM_DB_URL=postgresql://HOSTNAME:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# --- Vector Store (LlamaIndex + pgvector) ---
USE_PGVECTOR=True
EMBED_MODEL=models/gemini-embedding-001
PGVECTOR_COLLECTION=data_talk_vectors

# --- Redis Cache ---
REDIS_URL=your_redis_URL_here
CACHE_TTL=3600

MAX_QUERY_ROWS=1000
ALLOWED_SQL_PREFIXES=SELECT,WITH

FRONTEND_URL=http://localhost:3000

GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Multi-Agent APIs ---
GROQ_ROUTER_MODEL=llama-3.1-8b-instant
GROQ_QA_MODEL=llama-3.3-70b-versatile
GROQ_VISUALIZER_MODEL=llama-3.3-70b-versatile

OPENROUTER_SQL_MODEL=anthropic/claude-3.5-sonnet