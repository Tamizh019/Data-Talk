# 1. API KEYS

GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GITHUB_TOKEN=your_github_token_here
HF_TOKEN=your_hf_token_here

# 2. THE AI-AGENT MODELS 

ROUTER_MODEL=llama-3.1-8b-instant
DOC_RAG_MODEL=llama-3.3-70b-versatile
VISUALIZER_MODEL=gemini-3.1-pro-preview
SQL_GENERATOR_MODEL=anthropic/claude-3.5-sonnet
QA_CRITIC_MODEL=llama-3.3-70b-versatile
PYTHON_AGENT_MODEL=llama-3.3-70b-versatile
BUSINESS_ANALYST_MODEL=llama-3.3-70b-versatile
REFINER_MODEL=llama-3.1-8b-instant

# 3. DATABASES & CACHING

TARGET_DB_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/YOUR_DB_NAME
SYSTEM_DB_URL=postgresql://HOSTNAME:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

REDIS_URL=your_redis_URL_here
CACHE_TTL=3600

# 4. VECTOR STORE CONFIGURATION

USE_PGVECTOR=True
EMBED_MODEL=models/gemini-embedding-001
PGVECTOR_COLLECTION=data_talk_vectors

# 5. SECURITY & LIMITS

MAX_QUERY_ROWS=1000
ALLOWED_SQL_PREFIXES=SELECT,WITH
FRONTEND_URL=http://localhost:3000